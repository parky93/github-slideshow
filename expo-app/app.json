{
  "expo": {
    "name": "MTA App",
    "slug": "mta-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "mta-app",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mta.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2d7d2d"
      },
      "package": "com.mta.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFTS": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
