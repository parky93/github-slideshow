{
  "expo": {
    "name": "MTA Ready",
    "slug": "mta-ready",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "mta-ready",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0F1A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mta.ready"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2d7d2d"
      },
      "package": "com.mta.ready"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
